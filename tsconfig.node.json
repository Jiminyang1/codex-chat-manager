{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist/node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.cts",
    "electron/**/*.ts",
    "electron/**/*.cts",
    "test/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "renderer"
  ]
}
