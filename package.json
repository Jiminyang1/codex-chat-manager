{
  "name": "codex-chat-manager",
  "version": "0.1.0",
  "description": "Safe local manager for Codex Desktop projects and chat history.",
  "type": "module",
  "bin": {
    "codex-chat-manager": "./dist/node/src/cli.js"
  },
  "files": [
    "dist/node/src",
    "dist/node/electron",
    "dist/renderer",
    "src",
    "electron",
    "renderer",
    "build",
    "docs",
    "vite.config.ts",
    "tsconfig.json",
    "tsconfig.node.json",
    "tsconfig.renderer.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "npm run build:node --silent && node dist/node/src/server.js",
    "web": "npm run build:node --silent && node dist/node/src/server.js",
    "dev:renderer": "vite --host 127.0.0.1",
    "electron": "npm run build:node --silent && electron dist/node/electron/main.js",
    "electron:dev": "concurrently -k -s first -n node,renderer,electron \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"npm:dev:renderer\" \"wait-on http://127.0.0.1:5173 dist/node/electron/main.js && electron dist/node/electron/main.js --dev\"",
    "status": "npm run build:node --silent && node dist/node/src/cli.js status",
    "test": "npm run build:node --silent && node --test dist/node/test/*.test.js",
    "build:node": "tsc -p tsconfig.node.json",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:node && npm run typecheck:renderer && npm run build:renderer",
    "build:renderer": "vite build",
    "dist:mac": "npm run build && electron-builder --mac",
    "pack:check": "npm run build --silent && npm pack --dry-run",
    "prepare": "npm run build"
  },
  "build": {
    "appId": "dev.codex-chat-manager.app",
    "productName": "Codex Manager",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/node/src/**/*",
      "dist/node/electron/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/node/electron/main.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "codex",
    "codex-desktop",
    "chat-manager",
    "sqlite",
    "local-first"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
